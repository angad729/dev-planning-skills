---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));

let stars: string | null = null;
try {
  const res = await fetch('https://api.github.com/repos/angad729/deliberate', {
    headers: { 'User-Agent': 'deliberate-site' },
  });
  if (res.ok) {
    const data = await res.json();
    const count = data.stargazers_count ?? 0;
    stars = count >= 1000 ? `${(count / 1000).toFixed(1)}k` : String(count);
  }
} catch {
  stars = null;
}
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-mark">◐</span>
      <span class="logo-text">Deliberate</span>
    </a>
    <nav class="nav">
      <a href="/foundation/" class:list={['nav-link', isActive('/foundation') && 'active']}>Foundation</a>
      <a href="/skills/" class:list={['nav-link', isActive('/skills') && 'active']}>Skills</a>
      <a href="/failure-modes/" class:list={['nav-link', isActive('/failure-modes') && 'active']}>Failure Modes</a>
      <a href="/install/" class:list={['nav-link', isActive('/install') && 'active']}>Install</a>
      <a href="https://github.com/angad729/deliberate" class="nav-link nav-github" target="_blank" rel="noopener" aria-label="View on GitHub">
        <svg class="gh-icon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><path fill="currentColor" fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/></svg>
        {stars && <span class="gh-stars">{stars}</span>}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(249, 251, 249, 0.85);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid var(--line-soft);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink);
    font-weight: 600;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }
  .logo:hover { color: var(--forest-700); }
  .logo-mark {
    color: var(--forest-600);
    font-size: 1.25rem;
  }
  .nav {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }
  .nav-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ink-soft);
    padding: 0.5rem 0.875rem;
    border-radius: 4px;
    transition: all 120ms ease;
  }
  .nav-link:hover {
    color: var(--forest-800);
    background: var(--forest-50);
  }
  .nav-link.active {
    color: var(--forest-800);
    background: var(--forest-50);
  }
  .nav-github {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    margin-left: 0.25rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--line);
    background: var(--paper-2);
  }
  .nav-github:hover {
    border-color: var(--forest-500);
    background: var(--forest-50);
  }
  .gh-icon {
    color: var(--ink-soft);
    flex-shrink: 0;
  }
  .nav-github:hover .gh-icon {
    color: var(--forest-800);
  }
  .gh-stars {
    font-weight: 500;
    color: var(--ink-soft);
  }
  .nav-github:hover .gh-stars {
    color: var(--forest-800);
  }
  @media (max-width: 720px) {
    .nav { gap: 0; }
    .nav-link { padding: 0.5rem 0.5rem; font-size: 0.8125rem; }
    .nav-github {
      padding: 0.4rem 0.55rem;
      margin-left: 0.25rem;
    }
    .gh-stars { display: none; }
  }
</style>
