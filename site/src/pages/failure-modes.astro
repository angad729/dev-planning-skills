---
import Layout from '../layouts/Layout.astro';

type Mode = {
  id: string;
  name: string;
  description: string;
  counteredBy: { cmd: string; slug: string };
  category: string;
};

const MODES: Mode[] = [
  // Thinking
  { id: 'silent-assumption', name: 'Silent Assumption', description: 'Agent makes a wrong assumption on your behalf and runs with it without surfacing or checking.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Thinking' },
  { id: 'hidden-confusion', name: 'Hidden Confusion', description: 'Agent is confused but masks it with confident-sounding output instead of asking.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Thinking' },
  { id: 'sycophancy', name: 'Sycophancy', description: '"Great idea!" replacing "here are the problems with this idea." Agreement that\'s wrong is worse than disagreement that\'s right.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Thinking' },
  { id: 'no-plan', name: 'Jump Straight to Code', description: 'Multi-step task executed without a plan, leading to rework when the approach was wrong.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Thinking' },

  // Writing
  { id: 'overcomplication', name: 'Overcomplication', description: '1000 lines where 100 would do. Abstractions for a single caller. Frameworks in place of functions.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Writing' },
  { id: 'scope-creep', name: 'Scope Creep', description: 'Orthogonal edits smuggled into a diff. "While I was in there" changes that weren\'t asked for.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Writing' },
  { id: 'orphaned-code', name: 'Orphaned Code', description: 'Dead imports, unused helpers, commented-out blocks left behind by a change.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Writing' },
  { id: 'premature-abstraction', name: 'Premature Abstraction', description: 'Strategy pattern for a single type. Parameterizing what only ever has one value.', counteredBy: { cmd: '/architect', slug: 'architect' }, category: 'Writing' },

  // Execution
  { id: 'runaway-loop', name: 'Runaway Loop', description: 'Thirty minutes of the same failed approach, with increasingly elaborate workarounds.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Execution' },
  { id: 'confidence-without-calibration', name: 'Confidence Without Calibration', description: 'Authoritative tone for a guess. No signal of "I\'ve verified this" vs. "I\'m pattern-matching."', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Execution' },
  { id: 'context-drift', name: 'Context Drift', description: 'Decisions from earlier in the session silently reversed 100 messages later.', counteredBy: { cmd: '/deliberate', slug: 'deliberate' }, category: 'Execution' },

  // Product / Spec
  { id: 'spec-invention', name: 'Spec Invention', description: 'Reverse-engineering product intent from code, then building on those guesses.', counteredBy: { cmd: '/spec', slug: 'spec' }, category: 'Product' },
  { id: 'silent-requirement-fill', name: 'Silent Requirement Fill', description: 'PRD is vague, agent picks an interpretation without flagging, ships the wrong feature.', counteredBy: { cmd: '/spec', slug: 'spec' }, category: 'Product' },
  { id: 'spec-code-drift', name: 'Spec-Code Drift', description: 'Implementation quietly diverges from the PRD. Neither gets updated to match.', counteredBy: { cmd: '/spec', slug: 'spec' }, category: 'Product' },

  // Architecture
  { id: 'boundary-blur', name: 'Boundary Blur', description: 'Business logic in the controller. Utils that know about both the UI and the database.', counteredBy: { cmd: '/architect', slug: 'architect' }, category: 'Architecture' },
  { id: 'contract-break', name: 'Silent Contract Break', description: 'API or schema changed without considering unknown callers. Migration plan = none.', counteredBy: { cmd: '/architect', slug: 'architect' }, category: 'Architecture' },
  { id: 'state-ambiguity', name: 'Ambiguous State Ownership', description: 'Mutable state with no clear owner and no single source of truth.', counteredBy: { cmd: '/architect', slug: 'architect' }, category: 'Architecture' },

  // Testing
  { id: 'over-mocking', name: 'Over-Mocking', description: 'Tests that only talk to mocks. Green CI, broken production.', counteredBy: { cmd: '/test', slug: 'test' }, category: 'Testing' },
  { id: 'tautological-test', name: 'Tautological Test', description: 'Test that mirrors the implementation. Refactor that preserves behavior breaks the test.', counteredBy: { cmd: '/test', slug: 'test' }, category: 'Testing' },
  { id: 'flaky-test', name: 'Flaky Test', description: 'Intermittent failure tolerated via retry-until-green instead of fixed.', counteredBy: { cmd: '/test', slug: 'test' }, category: 'Testing' },
  { id: 'coverage-theater', name: 'Coverage Theater', description: 'Tests written to hit a number, not to protect a behavior.', counteredBy: { cmd: '/test', slug: 'test' }, category: 'Testing' },

  // Migration
  { id: 'big-bang', name: 'Big-Bang Migration', description: 'All callers updated in one PR. Can\'t deploy incrementally. Can\'t roll back.', counteredBy: { cmd: '/migrate', slug: 'migrate' }, category: 'Migration' },
  { id: 'half-finished', name: 'Half-Finished Migration', description: 'Old path and new path coexist forever. Two sources of truth. No trigger to finish.', counteredBy: { cmd: '/migrate', slug: 'migrate' }, category: 'Migration' },
  { id: 'unsafe-schema', name: 'Unsafe Schema Change', description: 'Lock-holding DDL run on a live table at peak traffic.', counteredBy: { cmd: '/migrate', slug: 'migrate' }, category: 'Migration' },

  // Debugging
  { id: 'symptom-masking', name: 'Symptom Masking', description: 'try/catch to swallow an unexplained error. Null check without knowing why it was null.', counteredBy: { cmd: '/debug', slug: 'debug' }, category: 'Debugging' },
  { id: 'random-walk-debugging', name: 'Random-Walk Debugging', description: 'Change something, run, repeat. No hypothesis, no bisection, no explanation when it works.', counteredBy: { cmd: '/debug', slug: 'debug' }, category: 'Debugging' },
  { id: 'fix-the-instance', name: 'Fix the Instance, Not the Class', description: 'Same bug in three places, patched once, mentioned nowhere.', counteredBy: { cmd: '/debug', slug: 'debug' }, category: 'Debugging' },

  // Review
  { id: 'rubber-stamp', name: 'Rubber-Stamp LGTM', description: 'Approval on code the reviewer didn\'t understand or didn\'t read.', counteredBy: { cmd: '/review', slug: 'review' }, category: 'Review' },
  { id: 'nit-review', name: 'Nit-Only Review', description: 'Forty comments on formatting, zero on correctness or architecture.', counteredBy: { cmd: '/review', slug: 'review' }, category: 'Review' },
  { id: 'missing-test-ignored', name: 'Missing Test Ignored', description: 'New code path ships with no test. Reviewer doesn\'t notice absence.', counteredBy: { cmd: '/review', slug: 'review' }, category: 'Review' },

  // Incident
  { id: 'shotgun-fix', name: 'Shotgun Fix', description: 'Five changes in one minute under pressure. Can\'t tell which one fixed it (or caused the next incident).', counteredBy: { cmd: '/incident', slug: 'incident' }, category: 'Incident' },
  { id: 'lost-evidence', name: 'Lost Evidence', description: 'Stabilization destroys the logs/state needed for root cause. No postmortem possible.', counteredBy: { cmd: '/incident', slug: 'incident' }, category: 'Incident' },
  { id: 'vague-postmortem', name: 'Vague Postmortem', description: '"We\'ll add better monitoring" with no owner, no deadline, no mechanism. Action items that rot.', counteredBy: { cmd: '/incident', slug: 'incident' }, category: 'Incident' },
];

const CATEGORIES = Array.from(new Set(MODES.map((m) => m.category)));
---

<Layout title="Failure Modes" description="A catalog of the failure modes Deliberate is built to counter.">
  <section class="modes-hero">
    <div class="container container-prose">
      <div class="eyebrow">Failure Modes</div>
      <h1 class="modes-title">What can go wrong, and which skill catches it.</h1>
      <p class="modes-lede">
        Every skill in Deliberate exists to counter something concrete. This page is the reverse index: start from a failure mode you recognize, jump to the skill that addresses it.
      </p>
      <p class="muted modes-count mono">
        {MODES.length} modes · {CATEGORIES.length} categories · most drawn from <a href="https://x.com/karpathy/status/1915485966336389126" target="_blank" rel="noopener">Karpathy's thread</a>.
      </p>
    </div>
  </section>

  <section class="modes-body">
    <div class="container">
      {CATEGORIES.map((cat) => {
        const items = MODES.filter((m) => m.category === cat);
        return (
          <div class="mode-cat">
            <div class="mode-cat-head">
              <h2 class="mode-cat-title">{cat}</h2>
              <span class="muted mono">{items.length} {items.length === 1 ? 'mode' : 'modes'}</span>
            </div>
            <div class="mode-grid">
              {items.map((m) => (
                <div class="mode-card">
                  <h3 class="mode-name">{m.name}</h3>
                  <p class="mode-desc">{m.description}</p>
                  <a href={`/skills/${m.counteredBy.slug}/`} class="mode-counter">
                    <span class="muted">Countered by</span>
                    <span class="cmd">{m.counteredBy.cmd}</span>
                    <span class="mode-arrow">→</span>
                  </a>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .modes-hero {
    padding: 5rem 0 3rem;
  }
  .modes-title {
    margin-top: 1rem;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    line-height: 1.1;
  }
  .modes-lede {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    color: var(--ink-soft);
  }
  .modes-count {
    margin-top: 1.25rem;
    font-size: 0.8125rem;
  }

  .modes-body {
    padding: 2rem 0 5rem;
  }

  .mode-cat {
    margin-bottom: 3.5rem;
  }
  .mode-cat:last-child { margin-bottom: 0; }
  .mode-cat-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line);
    margin-bottom: 1.25rem;
  }
  .mode-cat-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .mode-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
  }
  .mode-card {
    padding: 1.5rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    display: flex;
    flex-direction: column;
  }
  .mode-name {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .mode-desc {
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: none;
    flex: 1;
  }
  .mode-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed var(--line);
    font-size: 0.8125rem;
    color: var(--forest-700);
  }
  .mode-counter:hover { color: var(--forest-900); }
  .mode-counter .cmd { font-size: 0.875rem; }
  .mode-arrow {
    margin-left: auto;
    color: var(--forest-600);
    transition: transform 150ms ease;
  }
  .mode-counter:hover .mode-arrow {
    transform: translateX(3px);
  }
</style>
