---
import Layout from '../layouts/Layout.astro';
import { SKILLS, CATEGORIES } from '../lib/skills';

const foundation = SKILLS.find((s) => s.slug === 'deliberate')!;
const specialized = SKILLS.filter((s) => s.slug !== 'deliberate');
---

<Layout title="Deliberate">
  <section class="hero">
    <div class="container">
      <div class="eyebrow">A drop-in skill library for LLM coding agents</div>
      <h1 class="hero-title">
        Engineering discipline<br />
        for <span class="accent">AI harnesses</span>.
      </h1>
      <p class="hero-lede">
        Eight skills that mitigate the failure modes that show up once you're mostly programming in English: silent assumptions, sycophancy, overcomplication, half-finished migrations, tautological tests, and confidence without calibration.
      </p>
      <div class="hero-ctas">
        <a href="/install/" class="btn">Install in your project →</a>
        <a href="/skills/" class="btn btn-ghost">Browse all skills</a>
      </div>
      <div class="hero-meta mono muted">
        <span>One foundation.</span>
        <span>Seven specialized skills.</span>
        <span>Plain markdown.</span>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">01 — Foundation</div>
        <h2>The default load for any project.</h2>
        <p class="section-lede">
          <code>/deliberate</code> teaches your agent nine principles for how to write code - when to plan, when to push back, when to stop. Everything else in this library builds on top of it.
        </p>
      </div>

      <a href={`/skills/${foundation.slug}/`} class="foundation-card">
        <div class="foundation-header">
          <span class="cmd">{foundation.command}</span>
          <span class="foundation-arrow">→</span>
        </div>
        <p class="foundation-blurb">{foundation.blurb}</p>
        <div class="foundation-counters">
          <span class="eyebrow">Counters</span>
          <p>{foundation.counters}</p>
        </div>
      </a>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">02 — Language</div>
        <h2>Seven specialized skills.</h2>
        <p class="section-lede">
          Load these alongside the foundation when the task calls for them. Each is a standalone file - take what you need, skip what you don't.
        </p>
      </div>

      {CATEGORIES.filter((c) => c.key !== 'foundation').map((cat) => {
        const items = specialized.filter((s) => s.category === cat.key);
        return (
          <div class="category-block">
            <div class="category-head">
              <h3 class="category-title">{cat.label}</h3>
              <span class="muted category-count mono">{items.length} {items.length === 1 ? 'skill' : 'skills'}</span>
            </div>
            <p class="category-blurb muted">{cat.blurb}</p>
            <div class="skill-grid">
              {items.map((s) => (
                <a href={`/skills/${s.slug}/`} class="skill-card">
                  <div class="skill-card-top">
                    <span class="cmd">{s.command}</span>
                    <span class="skill-arrow">→</span>
                  </div>
                  <div class="skill-card-title">{s.tagline}</div>
                  <div class="skill-card-counter muted">{s.counters}</div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <div class="eyebrow">03 — Install</div>
        <h2>Drop it in. Reference it. Ship.</h2>
        <p class="section-lede">
          Every skill is plain markdown. No tool-specific syntax, no build step, no lock-in.
        </p>
      </div>

      <div class="install-grid">
        <div class="install-card install-card-primary">
          <div class="install-head">
            <span class="recommended-tag">Recommended</span>
            <span class="eyebrow">One-liner</span>
          </div>
          <pre><code>npx skills add angad729/deliberate</code></pre>
          <p class="install-blurb muted">
            Installs all eight skills. Works with Cursor, Claude Code, Codex, Gemini, and 40+ other agents via <a href="https://github.com/vercel-labs/skills" target="_blank" rel="noopener">vercel-labs/skills</a>.
          </p>
        </div>

        <div class="install-card">
          <div class="install-head">
            <span class="eyebrow">Manual / paste-in</span>
          </div>
          <p class="muted install-blurb">
            Prefer to control what lands in your repo? Clone the repo and reference skills from <code>CLAUDE.md</code>, <code>.cursorrules</code>, or paste into any system prompt. Plain markdown.
          </p>
          <a href="/install/" class="btn btn-ghost">Full install guide →</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-prose">
      <div class="eyebrow">Why</div>
      <h2 class="why-title">The models will keep writing code. <span class="accent">How</span> they write it is still up to us.</h2>
      <p class="why-body">
        In late 2025, Andrej Karpathy <a href="https://x.com/karpathy/status/1915485966336389126" target="_blank" rel="noopener">posted a thread</a> on what changed - and what didn't - as agent coding crossed a coherence threshold. The diagnosis was sharp:
      </p>
      <blockquote class="why-quote">
        "The models make wrong assumptions on your behalf and just run along with them without checking. They don't manage their confusion, don't seek clarifications, don't surface inconsistencies, don't present tradeoffs, don't push back when they should."
      </blockquote>
      <p class="why-body">
        Those are the failure modes Deliberate pushes against. Credit for the diagnosis is Karpathy's. This library is the practical extrapolation into files you can drop into a project.
      </p>
    </div>
  </section>

<style>
  .hero {
    padding: 6rem 0 5rem;
  }
  .hero-title {
    margin-top: 1.5rem;
    max-width: 16ch;
  }
  .accent {
    color: var(--forest-700);
    font-style: italic;
  }
  .hero-lede {
    margin-top: 2rem;
    font-size: 1.25rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 38rem;
  }
  .hero-ctas {
    margin-top: 2.5rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero-meta {
    margin-top: 3rem;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .section {
    padding: 5rem 0;
  }
  .section-alt {
    background: var(--paper-2);
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
  }
  .section-head {
    max-width: 44rem;
    margin-bottom: 3rem;
  }
  .section-head h2 {
    margin-top: 1rem;
  }
  .section-lede {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--ink-soft);
  }

  .foundation-card {
    display: block;
    padding: 2.5rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    transition: all 180ms ease;
    color: inherit;
  }
  .foundation-card:hover {
    border-color: var(--forest-500);
    background: var(--forest-50);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px rgba(27, 74, 43, 0.2);
  }
  .foundation-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .foundation-header .cmd {
    font-size: 1.5rem;
    font-weight: 500;
  }
  .foundation-arrow {
    font-size: 1.25rem;
    color: var(--forest-600);
    transition: transform 180ms ease;
  }
  .foundation-card:hover .foundation-arrow {
    transform: translateX(4px);
  }
  .foundation-blurb {
    font-size: 1.0625rem;
    color: var(--ink-soft);
    max-width: none;
    line-height: 1.6;
  }
  .foundation-counters {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px dashed var(--line);
  }
  .foundation-counters p {
    margin-top: 0.5rem;
    color: var(--muted);
    font-size: 0.9375rem;
    max-width: none;
  }

  .category-block {
    margin-bottom: 3rem;
  }
  .category-block:last-child { margin-bottom: 0; }
  .category-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line-soft);
  }
  .category-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }
  .category-count {
    font-size: 0.8125rem;
  }
  .category-blurb {
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    max-width: 48rem;
  }
  .skill-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.75rem;
  }
  .skill-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    transition: all 160ms ease;
    color: inherit;
  }
  .skill-card:hover {
    border-color: var(--forest-500);
    background: var(--forest-50);
  }
  .skill-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .skill-card-top .cmd { font-size: 1rem; }
  .skill-arrow { color: var(--forest-600); font-size: 0.875rem; }
  .skill-card-title {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .skill-card-counter {
    font-size: 0.8125rem;
    line-height: 1.5;
    margin-top: auto;
  }

  .install-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 1rem;
  }
  .install-card {
    padding: 1.75rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  .install-card-primary {
    background: linear-gradient(180deg, var(--forest-50) 0%, var(--paper-2) 100%);
    border-color: var(--forest-300);
  }
  .install-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .recommended-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--forest-800);
    background: var(--forest-100);
    padding: 0.25rem 0.625rem;
    border-radius: 3px;
  }
  .install-card pre {
    margin: 0 0 1rem;
    font-size: 0.875rem;
  }
  .install-card-primary pre {
    font-size: 0.9375rem;
  }
  .install-blurb {
    margin: 0 0 1.25rem;
    font-size: 0.9375rem;
    line-height: 1.55;
  }

  .why-title {
    margin-top: 1rem;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
  }
  .why-body {
    margin-top: 1.5rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .why-quote {
    margin: 2rem 0;
    padding: 1.5rem 1.75rem;
    background: var(--forest-50);
    border-left: 3px solid var(--forest-500);
    border-radius: 0 6px 6px 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    line-height: 1.5;
    color: var(--forest-800);
  }

  @media (max-width: 720px) {
    .install-grid { grid-template-columns: 1fr; }
    .section { padding: 3.5rem 0; }
    .hero { padding: 4rem 0 3.5rem; }
  }
</style>
</Layout>
