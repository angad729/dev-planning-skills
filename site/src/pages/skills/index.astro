---
import Layout from '../../layouts/Layout.astro';
import { SKILLS, CATEGORIES } from '../../lib/skills';
---

<Layout title="Skills" description="All Deliberate skills: Foundation, Think, Build, Investigate, Respond.">
  <section class="skills-hero">
    <div class="container container-prose">
      <div class="eyebrow">Skills</div>
      <h1 class="skills-title">One foundation. Seven specialized skills.</h1>
      <p class="skills-lede">
        <code>/deliberate</code> teaches the agent how to code. The rest teach the agent how to handle a specific kind of work. Load what you need.
      </p>
    </div>
  </section>

  <section class="skills-body">
    <div class="container">
      {CATEGORIES.map((cat) => {
        const items = SKILLS.filter((s) => s.category === cat.key);
        if (items.length === 0) return null;
        return (
          <div class="cat-block">
            <div class="cat-head">
              <h2 class="cat-title">{cat.label}</h2>
              <span class="muted mono cat-count">{items.length} {items.length === 1 ? 'skill' : 'skills'}</span>
            </div>
            <p class="cat-blurb muted">{cat.blurb}</p>

            <div class="cat-skills">
              {items.map((s, i) => (
                <a href={`/skills/${s.slug}/`} class="cat-skill">
                  <div class="cat-skill-num mono muted">{String(i + 1).padStart(2, '0')}</div>
                  <div class="cat-skill-main">
                    <div class="cat-skill-head">
                      <span class="cmd cat-skill-cmd">{s.command}</span>
                      <span class="cat-skill-tagline serif">{s.tagline}</span>
                    </div>
                    <p class="cat-skill-blurb">{s.blurb}</p>
                  </div>
                  <span class="cat-skill-arrow">→</span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .skills-hero {
    padding: 5rem 0 3rem;
  }
  .skills-title {
    margin-top: 1rem;
    font-size: clamp(2.25rem, 4vw, 3.25rem);
    line-height: 1.1;
  }
  .skills-lede {
    margin-top: 1.5rem;
    font-size: 1.125rem;
    color: var(--ink-soft);
  }

  .skills-body {
    padding: 1rem 0 5rem;
  }

  .cat-block {
    margin-bottom: 4rem;
  }
  .cat-block:last-child { margin-bottom: 0; }
  .cat-head {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line);
  }
  .cat-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: -0.015em;
  }
  .cat-count { font-size: 0.8125rem; }
  .cat-blurb {
    margin-top: 1rem;
    font-size: 0.9375rem;
    max-width: 48rem;
  }

  .cat-skills {
    margin-top: 1.5rem;
  }
  .cat-skill {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 1.5rem 1.75rem;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 6px;
    margin-bottom: 0.625rem;
    color: inherit;
    transition: all 160ms ease;
  }
  .cat-skill:hover {
    border-color: var(--forest-500);
    background: var(--forest-50);
    transform: translateX(2px);
  }
  .cat-skill-num {
    font-size: 0.8125rem;
    padding-top: 0.25rem;
    letter-spacing: 0.05em;
  }
  .cat-skill-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }
  .cat-skill-cmd {
    font-size: 1.0625rem;
    font-weight: 500;
  }
  .cat-skill-tagline {
    font-size: 1.0625rem;
    color: var(--ink);
  }
  .cat-skill-blurb {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 52rem;
  }
  .cat-skill-arrow {
    color: var(--forest-600);
    font-size: 1.125rem;
    padding-top: 0.125rem;
    transition: transform 160ms ease;
  }
  .cat-skill:hover .cat-skill-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .cat-skill {
      grid-template-columns: 1fr auto;
      gap: 1rem;
    }
    .cat-skill-num { display: none; }
  }
</style>
